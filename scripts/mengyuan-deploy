#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${MENGYUAN_REPO_DIR:-/home/ubuntu/noname}"
RELEASE_ROOT="/opt/zero-share/releases"
CURRENT_LINK="/opt/zero-share/current"
LOCK_FILE="/run/lock/mengyuan-deploy.lock"
ADMIN_HTPASSWD_FILE="/etc/nginx/.mengyuan-admin.htpasswd"
ADMIN_CREDENTIAL_FILE="/etc/zero-share-admin-credentials"

exec 9>"$LOCK_FILE"
flock -n 9 || exit 0

if [[ -n "$(runuser -u ubuntu -- git -C "$REPO_DIR" status --porcelain)" ]]; then
  echo "Refusing deployment: repository has uncommitted changes" >&2
  exit 1
fi

runuser -u ubuntu -- git -C "$REPO_DIR" fetch origin main
local_commit="$(runuser -u ubuntu -- git -C "$REPO_DIR" rev-parse HEAD)"
remote_commit="$(runuser -u ubuntu -- git -C "$REPO_DIR" rev-parse origin/main)"

if [[ "$local_commit" != "$remote_commit" ]]; then
  runuser -u ubuntu -- git -C "$REPO_DIR" merge --ff-only origin/main
fi

commit="$(runuser -u ubuntu -- git -C "$REPO_DIR" rev-parse HEAD)"
short_commit="${commit:0:12}"
release_dir="$RELEASE_ROOT/$commit"
previous_release=""
if [[ -L "$CURRENT_LINK" ]]; then
  candidate="$(readlink -f "$CURRENT_LINK" 2>/dev/null || true)"
  if [[ -n "$candidate" && "$candidate" != "$CURRENT_LINK" && -d "$candidate" ]]; then
    previous_release="$candidate"
  fi
fi

runuser -u ubuntu -- env PYTHONDONTWRITEBYTECODE=1 python3 -m unittest discover -s "$REPO_DIR/server" -p 'test_*.py'
runuser -u ubuntu -- env PYTHONDONTWRITEBYTECODE=1 python3 "$REPO_DIR/scripts/validate_static.py"

install -d -m 0755 "$RELEASE_ROOT"
if [[ ! -d "$release_dir" ]]; then
  install -d -m 0755 "$release_dir"
fi
for module in "$REPO_DIR"/server/*.py; do
  [[ "$(basename "$module")" == test_*.py ]] && continue
  mode=0644
  [[ "$(basename "$module")" == "feedback_server.py" ]] && mode=0755
  install -m "$mode" "$module" "$release_dir/$(basename "$module")"
done
install -d -m 0755 "$release_dir/site"
shopt -s nullglob
for page in "$REPO_DIR"/*.html; do
  install -m 0644 "$page" "$release_dir/site/$(basename "$page")"
done
for asset_dir in assets css data games js; do
  if [[ -d "$REPO_DIR/$asset_dir" ]]; then
    cp -a "$REPO_DIR/$asset_dir" "$release_dir/site/"
  fi
done

ln -sfn "$release_dir" "$CURRENT_LINK"
printf 'APP_VERSION=%s\n' "$short_commit" > /etc/zero-share-release.env
chmod 0644 /etc/zero-share-release.env
install -m 0644 "$REPO_DIR/server/zero-share-feedback.service" /etc/systemd/system/zero-share-feedback.service
install -m 0644 "$REPO_DIR/server/nginx-default.conf" /etc/nginx/sites-available/default
install -m 0755 "$REPO_DIR/scripts/mengyuan-deploy" /usr/local/sbin/mengyuan-deploy

if [[ ! -f "$ADMIN_HTPASSWD_FILE" ]]; then
  admin_user="admin"
  admin_password="$(python3 - <<'PY'
import secrets
alphabet = "ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz23456789"
print("MY-" + "".join(secrets.choice(alphabet) for _ in range(14)))
PY
)"
  admin_hash="$(openssl passwd -apr1 "$admin_password")"
  printf '%s:%s\n' "$admin_user" "$admin_hash" > "$ADMIN_HTPASSWD_FILE"
  chmod 0640 "$ADMIN_HTPASSWD_FILE"
  chown root:www-data "$ADMIN_HTPASSWD_FILE"
  {
    printf 'ADMIN_URL=http://124.223.181.116/resources-admin.html\n'
    printf 'ADMIN_USERNAME=%s\n' "$admin_user"
    printf 'ADMIN_PASSWORD=%s\n' "$admin_password"
  } > "$ADMIN_CREDENTIAL_FILE"
  chmod 0600 "$ADMIN_CREDENTIAL_FILE"
fi

systemctl daemon-reload
nginx -t
systemctl restart zero-share-feedback
systemctl reload nginx

healthy=false
for _ in {1..10}; do
  if curl --fail --silent --max-time 2 http://127.0.0.1:8787/health >/dev/null; then
    healthy=true
    break
  fi
  sleep 0.5
done

if [[ "$healthy" != true ]]; then
  echo "Health check failed; rolling back application release" >&2
  if [[ -n "$previous_release" && -d "$previous_release" ]]; then
    ln -sfn "$previous_release" "$CURRENT_LINK"
    systemctl restart zero-share-feedback
  fi
  exit 1
fi

find "$RELEASE_ROOT" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' \
  | sort -nr | tail -n +6 | cut -d' ' -f2- | xargs -r rm -rf

echo "Deployed 梦缘资源站 $short_commit"
